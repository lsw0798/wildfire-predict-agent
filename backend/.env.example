# Backend runtime configuration
# Copy to .env for local development.

APP_NAME=Wildfire Agent Backend
APP_VERSION=0.1.0

# Public wildfire/open data integration
# bigdata-forest.kr 오픈API 안내 기준 실시간 산불 API(todayFireGet)
WILDFIRE_API_BASE_URL=https://www.bigdata-forest.kr/todayFireGet
WILDFIRE_API_KEY=your_forest_api_key

# Local data paths (relative values resolve from the project root)
WILDFIRE_DATA_DIR=data
WILDFIRE_PROCESSED_DATA_PATH=data/processed/incidents.json

# Frontend origins allowed to call this API
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional future Kakao REST/local API usage (keep server-side only)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
